# Gmail SMTP credentials for /api/send-order
# Use a Gmail App Password (not the regular account password)
GMAIL_SMTP_USER=your.email@gmail.com
GMAIL_SMTP_APP_PASSWORD=your_app_password_here
GMAIL_FROM_EMAIL=your.email@gmail.com
# Email(s) that receive new order notifications. Comma-separated for multiple recipients.
ORDER_NOTIFICATION_EMAIL=your.email@gmail.com,another@gmail.com
