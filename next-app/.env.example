# Gmail SMTP credentials for /api/send-order
# Use a Gmail App Password (not the regular account password)
GMAIL_SMTP_USER=your.email@gmail.com
GMAIL_SMTP_APP_PASSWORD=your_app_password_here
GMAIL_FROM_EMAIL=your.email@gmail.com
# Email(s) that receive new order notifications. Comma-separated for multiple recipients.
ORDER_NOTIFICATION_EMAIL=your.email@gmail.com,another@gmail.com

# Meta (Facebook / Instagram) Pixel + Conversions API
# Get these from Events Manager: https://business.facebook.com/events_manager2/
# Pixel ID is public (sent to the browser). The access token is a server-side secret.
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Optional: only set this while testing in Events Manager > Test Events.
# Remove (or leave empty) before going live so events count as production.
META_CAPI_TEST_EVENT_CODE=
